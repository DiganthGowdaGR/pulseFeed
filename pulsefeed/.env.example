# Google Firestore Configuration
FIRESTORE_PROJECT_ID=your-google-project-id
GOOGLE_CLOUD_PROJECT=your-google-project-id
FIRESTORE_DATABASE_ID=(default)
GOOGLE_APPLICATION_CREDENTIALS=pulsefeed/your-service-account-key.json

# OMDb API Configuration
OMDB_API_KEY=your_omdb_api_key_here

# Weather API Configuration (e.g. OpenWeatherMap)
WEATHER_API_KEY=your_openweathermap_api_key_here

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_from_ai_studio
